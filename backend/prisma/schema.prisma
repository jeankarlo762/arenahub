generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  mrrValue      Decimal  @default(0)
  setupFee      Decimal  @default(0)
  active        Boolean  @default(true)
  bookingSlug   String?  @unique
  modulesConfig String?  // JSON: { "admin": [...], "operator": [...] }
  users         User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Branding por tenant — cor primária, logo (base64), nome de exibição e mensagens WhatsApp.
model TenantBranding {
  tenantId                  String   @id
  primaryColor              String   @default("#F2B705")
  logoUrl                   String?
  companyName               String?
  whatsappTemplate          String?  // confirmação enviada ao cliente
  whatsappReminderTemplate  String?  // lembrete 1h antes do agendamento
  whatsappOwnerTemplate     String?  // aviso de novo agendamento para o dono
  whatsappOwnerNumber       String?  // número do dono que recebe os avisos
  updatedAt                 DateTime @updatedAt
}

// Horário de funcionamento do estabelecimento (por dia da semana), aplicado a
// TODAS as quadras da arena. Substitui o horário por quadra (Schedule).
// dayOfWeek: 0=Dom ... 6=Sáb.
model BusinessHours {
  tenantId  String
  dayOfWeek Int
  openTime  String  @default("08:00")
  closeTime String  @default("22:00")
  active    Boolean @default(true)

  @@id([tenantId, dayOfWeek])
}

// Role: ADMIN | OPERATOR | SUPERADMIN
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         String   @default("OPERATOR")
  active       Boolean  @default(true)
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Court {
  id           String       @id @default(cuid())
  tenantId     String?
  name         String
  type         String
  description  String?
  capacity     Int?
  pricePerSlot Decimal      @default(0)
  slotMinutes  Int          @default(60)
  active       Boolean      @default(true)
  imageUrl     String?
  schedules    Schedule[]
  bookings     Booking[]
  tournaments  Tournament[]
  rentals      Rental[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
}

model Schedule {
  id        String  @id @default(cuid())
  tenantId  String?
  courtId   String
  court     Court   @relation(fields: [courtId], references: [id])
  dayOfWeek Int
  openTime  String
  closeTime String
  active    Boolean @default(true)

  @@index([tenantId])
}

// status: CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
model Booking {
  id            String   @id @default(cuid())
  tenantId      String?
  courtId       String
  court         Court    @relation(fields: [courtId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String?
  date          DateTime
  startTime     String
  endTime       String
  totalPrice     Decimal
  status         String    @default("CONFIRMED")
  notes          String?
  payment            Payment?
  reminderSentAt     DateTime? // marca quando a mensagem de confirmação de presença foi enviada
  presenceConfirmedAt DateTime? // marca quando o cliente confirmou presença pelo link
  createdAt          DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, courtId, date])
}

// method: CASH | CREDIT_CARD | DEBIT_CARD | PIX | TRANSFER
// status: PENDING | PAID | REFUNDED
model Payment {
  id        String    @id @default(cuid())
  tenantId  String?
  bookingId String    @unique
  booking   Booking   @relation(fields: [bookingId], references: [id])
  amount    Decimal
  method    String
  paidAt    DateTime?
  status    String    @default("PENDING")
  notes     String?
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

// status: DRAFT | OPEN | IN_PROGRESS | FINISHED | CANCELLED
// matchType: INDIVIDUAL | DOUBLES | TEAM
model Tournament {
  id           String           @id @default(cuid())
  tenantId     String?
  name         String
  description  String?
  sport        String
  startDate    DateTime
  endDate      DateTime
  status       String           @default("DRAFT")
  matchType    String           @default("TEAM")
  maxTeams     Int
  prizeInfo    String?
  imageUrl     String?
  champion     String?
  courtId      String?
  court        Court?           @relation(fields: [courtId], references: [id])
  teams        TournamentTeam[]
  pointsFirst  Int              @default(3)
  pointsSecond Int              @default(2)
  pointsThird  Int              @default(1)
  bracketData  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId])
}

model BarProduct {
  id          String         @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  price       Decimal
  costPrice   Decimal        @default(0)
  category    String?
  active      Boolean        @default(true)
  items       BarOrderItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
}

// status: OPEN | CLOSED | CANCELLED
model BarOrder {
  id            String           @id @default(cuid())
  tenantId      String?
  number        Int
  customerName  String
  status        String           @default("OPEN")
  total         Decimal          @default(0)
  paidAmount    Decimal          @default(0)
  notes         String?
  paymentMethod String?
  items         BarOrderItem[]
  transactions  BarTransaction[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, number])
  @@index([tenantId, status])
}

model BarTransaction {
  id            String   @id @default(cuid())
  tenantId      String?
  orderId       String
  order         BarOrder @relation(fields: [orderId], references: [id])
  amount        Decimal
  paymentMethod String
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([orderId])
}

model BarOrderItem {
  id        String     @id @default(cuid())
  tenantId  String?
  orderId   String
  order     BarOrder   @relation(fields: [orderId], references: [id])
  productId String
  product   BarProduct @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal
  subtotal  Decimal
  createdAt DateTime   @default(now())

  @@index([tenantId])
}

model PaymentFee {
  tenantId   String
  method     String
  feePercent Decimal @default(0)

  @@id([tenantId, method])
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String?
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rentals   Rental[]

  @@index([tenantId])
}

// weekdays: JSON string of int array [0-6] (0=Sun)
// slots: JSON string of [{startTime:"HH:MM",endTime:"HH:MM",price:number}]
// plan: one of "1M" | "3M" | "6M" | "12M" | "CUSTOM"
// paymentMethod: CASH | PIX | CREDIT_CARD | DEBIT_CARD | TRANSFER
// paymentDay: day of month (1-31) the rental is charged
// paymentFrequency: DAILY | MONTHLY
model Rental {
  id               String          @id @default(cuid())
  tenantId         String?
  courtId          String?
  court            Court?          @relation(fields: [courtId], references: [id])
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  clientName       String
  clientPhone      String?
  weekdays         String
  slots            String
  startDate        DateTime
  endDate          DateTime?
  plan             String?
  paymentMethod    String?
  paymentDay       Int?
  paymentFrequency String?
  notes            String?
  active           Boolean         @default(true)
  payments         RentalPayment[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tenantId])
}

// status: PENDING | PAID
model RentalPayment {
  id        String    @id @default(cuid())
  tenantId  String?
  rentalId  String
  rental    Rental    @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  dueDate   DateTime
  amount    Decimal   @default(0)
  status    String    @default("PENDING")
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([rentalId])
  @@index([tenantId])
}

// Registered tournament players. Points and tournaments-played are derived
// from finished tournaments (matched by name), not stored here.
model Player {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  age       Int?
  photo     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model TournamentTeam {
  id            String     @id @default(cuid())
  tenantId      String?
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  name          String
  players       String
  groupNumber   Int?
  finalPosition Int?
  createdAt     DateTime   @default(now())

  @@index([tenantId])
}

model BarCategory {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Senha mestra definida pelo super admin para acessar qualquer conta (suporte).
// Mantemos apenas o hash; a linha mais recente é a chave válida.
model MasterKey {
  id        String   @id @default(cuid())
  keyHash   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Token OTP de recuperação de senha via SMS (expira em 10 min, uso único).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// status: OPEN | IN_PROGRESS | RESOLVED | CLOSED
model SupportTicket {
  id             String   @id @default(cuid())
  tenantId       String?
  tenantName     String?
  userId         String?
  userName       String?
  userEmail      String?
  title          String
  description    String
  attachmentBase64 String?
  attachmentName   String?
  status         String   @default("OPEN")
  replyText      String?
  repliedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// Sessão do WhatsApp (Baileys) persistida no banco para sobreviver a
// reinícios do servidor (Railway tem filesystem efêmero). Guarda creds e
// chaves de sinalização como JSON serializado (BufferJSON).
model WhatsAppAuth {
  id    String @id
  value String
}

// Trilha de auditoria — registra toda criação/edição/exclusão feita no sistema.
// action: CREATE | UPDATE | DELETE | UPDATE_MANY | DELETE_MANY
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  userName  String?
  userEmail String?
  userRole  String?
  action    String
  entity    String
  entityId  String?
  summary   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity])
}

