NODE_ENV=development
PORT=3001

# Requer PostgreSQL — não suporta SQLite (schema.prisma usa provider="postgresql")
# Em desenvolvimento: use um PostgreSQL local, Docker, ou Railway com branch de dev
DATABASE_URL="postgresql://user:password@localhost:5432/arenamk_dev"

# OBRIGATÓRIO: ambos precisam de no mínimo 32 caracteres
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=substitua-por-um-segredo-de-no-minimo-32-caracteres
JWT_REFRESH_SECRET=outro-segredo-diferente-de-no-minimo-32-car

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
