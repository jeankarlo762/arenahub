{
  "name": "mtquadras-backend",
  "version": "1.0.0",
  "description": "Backend para sistema de gerenciamento de quadras esportivas",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && ./node_modules/.bin/tsc",
    "start": "npx prisma db push --accept-data-loss --skip-generate && node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear-tenants": "tsx prisma/clear-tenants.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  }
}
